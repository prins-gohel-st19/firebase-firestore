{
	"compilerOptions": {
		"module": "commonjs",
		"target": "es2018",
		"lib": ["es2018"],
		"moduleResolution": "node",
		"strict": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"skipLibCheck": true,
		"sourceMap": true,
		"outDir": "lib",
		"rootDir": "src"
	},
	"compileOnSave": true,
	"include": ["src/**/*.ts"],
	"exclude": ["node_modules", "lib"]
}
